# Public URL of the **web** app (used in checkout redirects and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated allowed browser origins for CORS (your web app origin in prod)
API_ALLOWED_ORIGIN=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

# Resend (set EMAIL_FROM to a verified domain sender in production)
RESEND_API_KEY=
EMAIL_FROM=

# Optional tuning
PRIZE_POOL_PER_SUBSCRIBER=5
DRAW_ENGINE_TIMEOUT_MS=20000
